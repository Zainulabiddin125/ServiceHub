@{
    ViewData["Title"] = "Employee Detail Report";
}

<style>
    .Cust-card-margin { margin: 5px !important; }
    .table { margin-bottom: 0 !important; }
    .dt-buttons .btn { margin-right: 5px !important; }
    .dt-buttons .btn i { margin-right: 5px !important; }
    .btn-dt-primary  { background-color:#0d6efd!important; border-color:#0d6efd!important; border-radius:5px!important; color:#fff!important; }
    .btn-dt-success  { background-color:#198754!important; border-color:#198754!important; border-radius:5px!important; color:#fff!important; }
    .btn-dt-danger   { background-color:#dc3545!important; border-color:#dc3545!important; border-radius:5px!important; color:#fff!important; }
    .btn-dt-warning  { background-color:#ffc107!important; border-color:#ffc107!important; border-radius:5px!important; color:#000!important; }
    .fraud-row td { background-color: #fff3cd !important; }
    .fraud-badge { font-size:0.7rem; }
    .finger-bar { display:inline-block; width:14px; height:22px; border-radius:3px; margin:1px; vertical-align:bottom; }
</style>

<div class="row">
    <div class="col-lg-12">
        <div class="card Cust-card-margin">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h2 class="mb-0">
                    <i class="fas fa-fingerprint text-primary me-2"></i>Employee Detail Report
                </h2>
                <div>
                    <a href="/HR/EmployeeDetailReport/ExportListExcel" class="btn btn-success btn-sm">
                        <i class="fas fa-file-excel me-1"></i> Export All (Excel)
                    </a>
                </div>
            </div>
            <div class="card-body">

                <!-- Summary Stats -->
                <div class="row mb-3" id="summaryStats" style="display:none!important">
                    <div class="col-md-3">
                        <div class="info-box shadow-sm">
                            <span class="info-box-icon bg-primary"><i class="fas fa-users"></i></span>
                            <div class="info-box-content">
                                <span class="info-box-text">Total Employees</span>
                                <span class="info-box-number" id="statTotal">—</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="info-box shadow-sm">
                            <span class="info-box-icon bg-success"><i class="fas fa-fingerprint"></i></span>
                            <div class="info-box-content">
                                <span class="info-box-text">Biometric Enrolled</span>
                                <span class="info-box-number" id="statEnrolled">—</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="info-box shadow-sm">
                            <span class="info-box-icon bg-warning"><i class="fas fa-exclamation-triangle"></i></span>
                            <div class="info-box-content">
                                <span class="info-box-text">Not Enrolled</span>
                                <span class="info-box-number" id="statNotEnrolled">—</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="info-box shadow-sm">
                            <span class="info-box-icon bg-danger"><i class="fas fa-shield-alt"></i></span>
                            <div class="info-box-content">
                                <span class="info-box-text">Fraud Alerts</span>
                                <span class="info-box-number" id="statFraud">—</span>
                            </div>
                        </div>
                    </div>
                </div>

                <table id="empTable"
                       class="table table-striped table-bordered table-hover"
                       style="width:100%">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Employee ID</th>
                            <th>Name</th>
                            <th>Biometric Status</th>
                            <th>Fingers Enrolled</th>
                            <th>Machines</th>
                            <th>Last Attendance</th>
                            <th>Enrollment Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
$(document).ready(function () {
    var totalCount = 0, enrolledCount = 0, notEnrolledCount = 0, fraudCount = 0;

    var table = $('#empTable').DataTable({
        processing: true,
        serverSide: true,
        ajax: {
            url: '/HR/EmployeeDetailReport/GetEmployees',
            type: 'POST',
            dataSrc: function(json) {
                // Compute summary stats from the FULL result (first load)
                totalCount     = json.recordsFiltered;
                enrolledCount  = json.data.filter(r => r.biometricStatus === 'Active').length;
                notEnrolledCount = json.data.filter(r => r.biometricStatus === 'Not Enrolled').length;
                fraudCount     = json.data.filter(r => r.fraudAlert).length;
                $('#statTotal').text(totalCount);
                $('#statEnrolled').text(enrolledCount);
                $('#statNotEnrolled').text(notEnrolledCount);
                $('#statFraud').text(fraudCount);
                $('#summaryStats').show();
                return json.data;
            }
        },
        columns: [
            { data: null, render: function(d, t, r, m) { return m.row + 1 + m.settings._iDisplayStart; }, orderable: false, width:'40px' },
            { data: 'empNo' },
            { data: 'empName' },
            {
                data: 'biometricStatus',
                render: function(d) {
                    return d === 'Active'
                        ? '<span class="badge bg-success"><i class="fas fa-fingerprint me-1"></i>Active</span>'
                        : '<span class="badge bg-secondary"><i class="fas fa-times me-1"></i>Not Enrolled</span>';
                }
            },
            {
                data: 'totalFingersEnrolled',
                render: function(d, t, r) {
                    if (d === 0) return '<span class="text-muted">—</span>';
                    var cls = d > 10 ? 'bg-danger' : 'bg-primary';
                    return '<span class="badge ' + cls + '">' + d + '</span>';
                }
            },
            {
                data: 'machinesAssigned',
                render: function(d) {
                    return d > 0 ? '<span class="badge bg-info text-dark">' + d + '</span>' : '<span class="text-muted">—</span>';
                }
            },
            {
                data: 'lastAttendance',
                render: function(d) { return d || '<span class="text-muted">Never</span>'; }
            },
            { data: 'enrollmentDate', render: function(d) { return d || '—'; } },
            {
                data: 'isActive',
                render: function(d) {
                    return d ? '<span class="badge bg-success">Active</span>'
                             : '<span class="badge bg-danger">Inactive</span>';
                }
            },
            {
                data: 'empNo',
                orderable: false,
                render: function(d, t, r) {
                    var alert = r.fraudAlert
                        ? '<span class="badge bg-danger fraud-badge ms-1" title="' + (r.fraudReason||'') + '"><i class="fas fa-exclamation-triangle"></i> Alert</span>'
                        : '';
                    return '<a href="/HR/EmployeeDetailReport/Detail/' + encodeURIComponent(d) + '" '
                         + 'class="btn btn-sm btn-primary"><i class="fas fa-eye me-1"></i>View</a>' + alert;
                }
            }
        ],
        createdRow: function(row, data) {
            if (data.fraudAlert) $(row).addClass('fraud-row').attr('title', data.fraudReason);
        },
        dom: '<"row"<"col-sm-2"l><"col-sm-10"Bf>>' +
             '<"row"<"col-sm-12"tr>>' +
             '<"row"<"col-sm-5"i><"col-sm-7"p>>',
        pageLength: 25,
        lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]],
        order: [[1, 'asc']],
        buttons: [
            { extend: 'copy',  text: '<i class="fas fa-copy"></i> Copy',  className: 'btn btn-dt-primary btn-sm' },
            { extend: 'print', text: '<i class="fas fa-print"></i> Print', className: 'btn btn-dt-warning btn-sm' },
            {
                text: '<i class="fas fa-file-excel"></i> Export (Excel)',
                className: 'btn btn-dt-success btn-sm',
                action: function(e, dt) {
                    var sv = $('#empTable_filter input').val();
                    window.location.href = '/HR/EmployeeDetailReport/ExportListExcel?search=' + encodeURIComponent(sv||'');
                }
            }
        ]
    });
});
</script>
}
