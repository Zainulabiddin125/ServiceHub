@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
}

<div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

<form id="account" method="post">
    <!-- Email -->
    <div class="auth-field">
        <i class="fas fa-envelope field-icon"></i>
        <div class="form-floating">
            <input asp-for="Input.Email" class="form-control" autocomplete="username"
                   aria-required="true" placeholder="name@example.com" />
            <label asp-for="Input.Email">Email Address</label>
        </div>
        <span asp-validation-for="Input.Email" class="text-danger"></span>
    </div>

    <!-- Password -->
    <div class="auth-field">
        <i class="fas fa-lock field-icon"></i>
        <div class="form-floating">
            <input asp-for="Input.Password" id="Input_Password" class="form-control" autocomplete="current-password"
                   aria-required="true" placeholder="password" />
            <label asp-for="Input.Password">Password</label>
        </div>
        <button type="button" class="auth-toggle-pw" id="togglePassword" title="Show password">
            <i class="fas fa-eye" id="toggleIcon"></i>
        </button>
        <span asp-validation-for="Input.Password" class="text-danger"></span>
    </div>

    <!-- Remember + Forgot -->
    <div class="auth-remember">
        <div class="form-check">
            <input class="form-check-input" asp-for="Input.RememberMe" />
            <label class="form-check-label" asp-for="Input.RememberMe">Remember me</label>
        </div>
        <a asp-page="./ForgotPassword">Forgot password?</a>
    </div>

    <!-- Submit -->
    <button type="submit" class="auth-btn">
        <i class="fas fa-sign-in-alt"></i> Sign In
    </button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
            document.getElementById('togglePassword').addEventListener('click', function () {
            var passwordInput = document.querySelector('input[type="password"], input[name="Input.Password"]');
            var toggleIcon = document.getElementById('toggleIcon');

            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.classList.remove('fa-eye');
                toggleIcon.classList.add('fa-eye-slash');
                this.title = 'Hide password';
            } else {
                passwordInput.type = 'password';
                toggleIcon.classList.remove('fa-eye-slash');
                toggleIcon.classList.add('fa-eye');
                this.title = 'Show password';
            }
        });
    </script>
}
